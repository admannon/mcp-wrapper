{
  "name": "mcp-wrapper",
  "version": "1.0.0",
  "description": "MCP server to wrap duplicate commands and tools with server name prefix",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-wrapper": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
